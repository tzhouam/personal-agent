# LLM — Anthropic SDK; leave ANTHROPIC_BASE_URL empty for the real Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=

# GitHub — fine-grained PAT, read-only (repos, notifications)
GITHUB_TOKEN=
GITHUB_USER=

# Email delivery — Resend HTTP API first, SMTP fallback
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DIGEST_TO=

# Resume sync — Overleaf git-bridge URL (https://git.overleaf.com/<project-id>)
# or any git remote. Empty = resume sync disabled.
RESUME_REMOTE_URL=

# Personal website — "owner/name" GitHub Pages repo (e.g. you/you.github.io).
# The agent renders the site from the profile (deterministic, no LLM) and
# pushes directly to the default branch. Empty = disabled.
WEBSITE_REPO=

# Chat daemon (`assistant serve`) — loopback HTTP for the OpenClaw bridge +
# email chat polling. Email works with the SMTP creds above: mail yourself
# with a subject starting "agent" (e.g. "agent: what's due?"). Optional knobs:
# SERVE_PORT=8377
# SERVE_TOKEN=            # bearer auth for the loopback API (optional)
# CHAT_POLL_SECONDS=60
# CHAT_SUBJECT_PREFIX=agent
# SERVE_SESSION_TURNS=10           # chat exchanges kept per session
# CHAT_HISTORY_MAX_AGE_HOURS=48    # older turns never enter a prompt;
#                                  # daily curate phase prunes them from disk

# Finance ledger — chat-logged income/expense records (finance.yaml in
# the profile repo). Summaries are computed in code, not by the LLM:
# FINANCE_CURRENCY=CNY

# Vision — lets chat understand attached images (WeChat photos, email
# attachments, `assistant ask --image`). If the main LLM is natively
# multimodal, set LLM_SUPPORTS_IMAGES=true (see LLM section) and skip this.
# For a text-only main LLM, images are described by a remote multimodal API
# first (no local models — API only):
# VISION_API_KEY=         # key for the multimodal model API
# VISION_PROVIDER=anthropic   # wire format: anthropic | openai
#                             # (openai also covers Gemini's openai-compatible
#                             # endpoint and DashScope/Qwen-VL)
# VISION_BASE_URL=        # empty = the provider's default endpoint
# VISION_MODEL=           # e.g. claude-sonnet-4-6 / gpt-5-mini / gemini-2.5-flash
# VISION_MAX_IMAGES=3     # images processed per message

# Deliver-phase WeChat announce — off by default; enable only after removing
# --announce from the OpenClaw cron job (or the 07:00 run pings twice):
# WECHAT_ANNOUNCE=true
# ANNOUNCE_ACCOUNT=       # gateway account id (…-im-bot)
# ANNOUNCE_TO=            # owner's WeChat im id

# WeCom (企业微信) channel — the agent talks to you inside WeChat via the
# WeChat plugin. Create a free WeCom org + self-built app; sending needs only
# these three (+ your member id):
WECOM_CORP_ID=
WECOM_SECRET=
WECOM_AGENT_ID=
WECOM_OWNER_USERID=
# Receiving replies additionally needs the app's callback URL publicly routed
# to this machine (tunnel/VPS → WECOM_CALLBACK_PORT, default 8329):
WECOM_TOKEN=
WECOM_AES_KEY=
# WECOM_CALLBACK_PORT=8329

# Web search — keyless DuckDuckGo Lite by default. Preferred keyed backends
# (used in this order, DDG stays the fallback):
# 1. Gemini grounding (RECOMMENDED — one key, search+answer in one call,
#    free ~1500/day on 2.5-class models): aistudio.google.com → Get API key
# GEMINI_API_KEY=
# GEMINI_SEARCH_MODEL=gemini-2.5-flash
# 2. Google Programmable Search — legacy: whole-web engines can no longer be
#    created (since 2026-01); only useful with a pre-existing whole-web cx:
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=
# 3. Tavily — free 1,000 credits/month, no card (app.tavily.com):
# TAVILY_API_KEY=
# 4. Brave Search — free ~1-2k queries/month, no card (api-dashboard.search.brave.com):
# BRAVE_API_KEY=

# Research digest knobs (defaults shown; sources list lives in config/sources.yaml)
# ARXIV_LOOKBACK_DAYS=7
# ARXIV_MAX_PER_QUERY=30
# RESEARCH_TOP_PAPERS=10
# RESEARCH_TOP_FEED_ITEMS=8

# Gmail IMAP collector (reuses SMTP_USER/SMTP_PASSWORD; headers only)
# GMAIL_ENABLED=true
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993

# Data directory (default ~/.personal-agent) and collection window
# DATA_DIR=
# LOOKBACK_HOURS=26
